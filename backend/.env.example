# Meta / WhatsApp Cloud API
META_GRAPH_API_VERSION=v20.0
META_ACCESS_TOKEN=your_meta_access_token_here
META_VERIFY_TOKEN=your_custom_verify_token_here
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
DEFAULT_WABA_ID=your_waba_id_here

# Database (MySQL/MariaDB)
DATABASE_URL="mysql://user:password@localhost:3306/whatsapp_supervisor"

# Auth
JWT_SECRET=your_very_long_random_jwt_secret_here
JWT_EXPIRES_IN=7d

# Web Push VAPID
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:admin@yourdomain.com

# App
APP_BASE_URL=https://yourdomain.com
PORT=3001
NODE_ENV=production

# Alert settings (defaults)
ALERT_UNANSWERED_AFTER_MINUTES=10
