// Prisma schema for WhatsApp Multi-Store Supervisor Panel
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  name          String   @db.VarChar(255)
  email         String   @unique @db.VarChar(255)
  passwordHash  String   @map("password_hash") @db.VarChar(255)
  role          UserRole @default(manager)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  messages          Message[]
  auditLogs         AuditLog[]
  pushSubscriptions PushSubscription[]
  assignedConversations Conversation[] @relation("AssignedUser")
  userStores        UserStore[]

  @@map("users")
}

enum UserRole {
  owner
  manager
  attendant
  admin
}

model Store {
  id                  Int      @id @default(autoincrement())
  name                String   @db.VarChar(255)
  displayName         String   @map("display_name") @db.VarChar(255)
  whatsappPhoneNumber String   @map("whatsapp_phone_number") @db.VarChar(50)
  metaPhoneNumberId   String   @unique @map("meta_phone_number_id") @db.VarChar(100)
  metaWabaId          String   @map("meta_waba_id") @db.VarChar(100)
  active              Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  conversations Conversation[]
  messages      Message[]
  userStores    UserStore[]

  @@map("stores")
}

model UserStore {
  userId  Int
  storeId Int
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store   Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([userId, storeId])
  @@map("user_stores")
}

model Contact {
  id          Int      @id @default(autoincrement())
  waId        String   @unique @map("wa_id") @db.VarChar(50)
  phoneNumber String   @map("phone_number") @db.VarChar(50)
  profileName String?  @map("profile_name") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  conversations Conversation[]
  messages      Message[]

  @@map("contacts")
}

model Conversation {
  id                     Int                @id @default(autoincrement())
  storeId                Int                @map("store_id")
  contactId              Int                @map("contact_id")
  status                 ConversationStatus @default(new)
  lastCustomerMessageAt  DateTime?          @map("last_customer_message_at")
  freeWindowExpiresAt    DateTime?          @map("free_window_expires_at")
  lastMessageAt          DateTime?          @map("last_message_at")
  lastMessagePreview     String?            @map("last_message_preview") @db.VarChar(500)
  firstResponseAt        DateTime?          @map("first_response_at")
  firstResponseSeconds   Int?               @map("first_response_seconds")
  unreadCountOwner       Int                @default(0) @map("unread_count_owner")
  unreadCountStore       Int                @default(0) @map("unread_count_store")
  assignedUserId         Int?               @map("assigned_user_id")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  store        Store    @relation(fields: [storeId], references: [id])
  contact      Contact  @relation(fields: [contactId], references: [id])
  assignedUser User?    @relation("AssignedUser", fields: [assignedUserId], references: [id])
  messages     Message[]

  @@map("conversations")
}

enum ConversationStatus {
  new
  open
  waiting_store_response
  waiting_customer
  resolved
  blocked_24h_expired
}

model Message {
  id             Int            @id @default(autoincrement())
  conversationId Int            @map("conversation_id")
  storeId        Int            @map("store_id")
  contactId      Int            @map("contact_id")
  metaMessageId  String?        @unique @map("meta_message_id") @db.VarChar(255)
  direction      MessageDir
  type           MessageType    @default(text)
  textBody       String?        @map("text_body") @db.Text
  mediaId        String?        @map("media_id") @db.VarChar(255)
  mediaMimeType  String?        @map("media_mime_type") @db.VarChar(100)
  mediaFilename  String?        @map("media_filename") @db.VarChar(255)
  status         MessageStatus  @default(received)
  sentByUserId   Int?           @map("sent_by_user_id")
  timestamp      DateTime
  rawPayload     Json?          @map("raw_payload")
  createdAt      DateTime       @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id])
  contact      Contact      @relation(fields: [contactId], references: [id])
  sentByUser   User?        @relation(fields: [sentByUserId], references: [id])

  @@map("messages")
}

enum MessageDir {
  inbound
  outbound
}

enum MessageType {
  text
  image
  audio
  document
  video
  location
  unknown
}

enum MessageStatus {
  received
  sent
  delivered
  read
  failed
  blocked
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  endpoint  String   @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  userAgent String?  @map("user_agent") @db.VarChar(500)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?     @map("user_id")
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   Int?     @map("entity_id")
  detailsJson Json?   @map("details_json")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model SystemConfig {
  id    Int     @id @default(autoincrement())
  key   String  @unique @db.VarChar(100)
  value String  @db.Text

  @@map("system_config")
}
